# Copy values into Vercel Project Settings > Environment Variables.
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
AGENT_ENABLED=true
# Default: anthropic/claude-haiku-4.5 through OpenRouter.
AGENT_MODEL=anthropic/claude-haiku-4.5
AGENT_DAILY_CAP=20
# Comma-separated SHA-256 hashes of private company inputs. Required; missing fails closed.
BLOCKED_INPUT_HASHES=
# Free Upstash Redis REST database. Required; missing fails closed.
KV_REST_API_URL=
KV_REST_API_TOKEN=
